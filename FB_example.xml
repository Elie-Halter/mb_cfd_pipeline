<?xml version="1.0" encoding="UTF-8" ?>
<svMultiPhysicsFile version="1.0">

<GeneralSimulationParameters>
  <Number_of_spatial_dimensions> 3 </Number_of_spatial_dimensions>
  <Number_of_time_steps> 1948 </Number_of_time_steps>
  <Time_step_size> 0.001 </Time_step_size>
  <Restart_file_name> results </Restart_file_name>
  <Increment_in_saving_restart_files> 10 </Increment_in_saving_restart_files>
  <Start_saving_after_time_step> 1 </Start_saving_after_time_step>
  <Continue_previous_simulation> false </Continue_previous_simulation>
  <Save_averaged_results> true </Save_averaged_results>
  <Save_results_to_VTK_format> true </Save_results_to_VTK_format>
  <Name_prefix_of_saved_VTK_files> results </Name_prefix_of_saved_VTK_files>
  <Increment_in_saving_VTK_files> 10 </Increment_in_saving_VTK_files>
  <Spectral_radius_of_infinite_time_step> 0.2 </Spectral_radius_of_infinite_time_step>
  <Searched_file_name_to_trigger_stop>STOP_SIM</Searched_file_name_to_trigger_stop>
  <Verbose> true </Verbose>
  <Warning> true </Warning>
  <Debug> false </Debug>
</GeneralSimulationParameters>

<Add_mesh name="lumen">
  <Mesh_file_path> mesh/mesh-complete.mesh.vtu </Mesh_file_path>
  <Mesh_scale_factor> 0.1 </Mesh_scale_factor>
  <Add_face name="asc">
    <Face_file_path> mesh/mesh-surfaces/asc.vtp </Face_file_path>
  </Add_face>
  <Add_face name="desc">
    <Face_file_path> mesh/mesh-surfaces/desc.vtp </Face_file_path>
  </Add_face>
  <Add_face name="btca">
    <Face_file_path> mesh/mesh-surfaces/btca.vtp </Face_file_path>
  </Add_face>
  <Add_face name="lcca">
    <Face_file_path> mesh/mesh-surfaces/lcca.vtp </Face_file_path>
  </Add_face>
  <Add_face name="lsa">
    <Face_file_path> mesh/mesh-surfaces/lsa.vtp </Face_file_path>
  </Add_face>
  <Add_face name="wall">
    <Face_file_path> mesh/mesh-surfaces/wall.vtp </Face_file_path>
  </Add_face>
</Add_mesh>

<Add_equation type="fluid">
  <Coupled> true </Coupled>
  <Min_iterations> 1 </Min_iterations>
  <Max_iterations> 5 </Max_iterations>   <!-- MB diverge a 3 (residus 10-30% accumules) ; >=5 obligatoire -->
  <Tolerance> 1e-3 </Tolerance>          <!-- resserre 5e-3->1e-3 ; 1e-5 (Dell'Agnello) ferait crasher le MB -->

  <Backflow_stabilization_coefficient> 0.3 </Backflow_stabilization_coefficient>
  <Density> 1.06 </Density>
  <Viscosity model="Constant">
    <Value> 0.04 </Value>
  </Viscosity>
  <LS type="NS">     <!-- NS linear solver: GMRES, Krylov 100, generous max iters (needed at systole) -->
    <Max_iterations> 100 </Max_iterations>
    <Tolerance> 5e-3 </Tolerance>
    <Krylov_space_dimension> 100 </Krylov_space_dimension>
    <NS_GM_max_iterations> 3 </NS_GM_max_iterations>
    <NS_GM_tolerance> 1e-2 </NS_GM_tolerance>
    <NS_CG_max_iterations> 200 </NS_CG_max_iterations>
    <NS_CG_tolerance> 1e-2 </NS_CG_tolerance>
    <Linear_algebra type="fsils">
      <Preconditioner> fsils </Preconditioner>
    </Linear_algebra>
  </LS>
  <Output type="Spatial">
    <Velocity> true </Velocity>
    <Pressure> true </Pressure>
    <WSS> true </WSS>
  </Output>
  <Add_BC name="asc">
    <Type> Dirichlet </Type>
    <Time_dependence> Unsteady </Time_dependence>
    <Temporal_values_file_path> flow_rate.txt </Temporal_values_file_path>
    <Profile> Flat </Profile>
    <Zero_out_perimeter> true </Zero_out_perimeter>
    <Impose_flux> true </Impose_flux>
  </Add_BC>
  <Add_BC name="wall">
    <Type> Dirichlet </Type>
    <Time_dependence> Steady </Time_dependence>
    <Value> 0 </Value>
  </Add_BC>
  <Add_BC name="desc">
    <Type> Neumann </Type>
    <Time_dependence> RCR </Time_dependence>
    <!-- Calibrated to MRI split 75.3% (Option 3, R_prox/R_tot=0.091, tau=1.5s) -->
    <RCR_values>
      <Proximal_resistance> 187.9 </Proximal_resistance>
      <Capacitance> 7.9801e-04 </Capacitance>
      <Distal_resistance> 1879.7 </Distal_resistance>
      <Distal_pressure> 0 </Distal_pressure>
      <Initial_pressure> 0 </Initial_pressure>
    </RCR_values>
  </Add_BC>
  <Add_BC name="lcca">
    <Type> Neumann </Type>
    <Time_dependence> RCR </Time_dependence>
    <!-- Calibrated to MRI split 4.7% (Option 3) -->
    <RCR_values>
      <Proximal_resistance> 3011.1 </Proximal_resistance>
      <Capacitance> 4.9809e-05 </Capacitance>
      <Distal_resistance> 30114.8 </Distal_resistance>
      <Distal_pressure> 0 </Distal_pressure>
      <Initial_pressure> 0 </Initial_pressure>
    </RCR_values>
  </Add_BC>
  <Add_BC name="btca">
    <Type> Neumann </Type>
    <Time_dependence> RCR </Time_dependence>
    <!-- Calibrated to MRI split 12.6% (Option 3) -->
    <RCR_values>
      <Proximal_resistance> 1123.2 </Proximal_resistance>
      <Capacitance> 1.3353e-04 </Capacitance>
      <Distal_resistance> 11233.3 </Distal_resistance>
      <Distal_pressure> 0 </Distal_pressure>
      <Initial_pressure> 0 </Initial_pressure>
    </RCR_values>
  </Add_BC>
  <Add_BC name="lsa">
    <Type> Neumann </Type>
    <Time_dependence> RCR </Time_dependence>
    <!-- Calibrated to MRI split 7.5% (Option 3) -->
    <RCR_values>
      <Proximal_resistance> 1887.0 </Proximal_resistance>
      <Capacitance> 7.9483e-05 </Capacitance>
      <Distal_resistance> 18871.9 </Distal_resistance>
      <Distal_pressure> 0 </Distal_pressure>
      <Initial_pressure> 0 </Initial_pressure>
    </RCR_values>
  </Add_BC>
</Add_equation>



</svMultiPhysicsFile>
