+void read_prescribed_disp_txt(ComMod& com_mod, MBType& lMB, const faceType& lFa,
+    const std::string& fName, const Array<double>& ref_coords)
+{
+  std::ifstream file(fName);
+  if (!file.is_open()) {
+    throw std::runtime_error("[read_prescribed_disp_txt] Cannot open file: " + fName);
+  }
+
+  int num_nodes_file, num_phases;
+  file >> num_nodes_file >> num_phases;
+
+  if (num_nodes_file <= 0 || num_phases <= 0) {
+    throw std::runtime_error("[read_prescribed_disp_txt] Invalid header in file: " + fName);
+  }
+
+  const int nsd = com_mod.nsd;
+  const int nNo = lFa.nNo;
 
+  lMB.dof    = nsd;
+  lMB.nTP    = num_phases;
+  lMB.t.resize(num_phases);
+  lMB.d.resize(nsd, nNo, num_phases);
+
+// Build the list of cap node IDs to exclude
+// by reading all faces of the same mesh except the wall
+std::set<int> cap_node_ids;
+for (int iM2 = 0; iM2 < com_mod.nMsh; iM2++) {
+  auto& msh2 = com_mod.msh[iM2];
+  for (int iFa2 = 0; iFa2 < msh2.nFa; iFa2++) {
+    auto& fa2 = msh2.fa[iFa2];
+    if (fa2.name == lFa.name) continue; // skip the wall itself
+    for (int a = 0; a < fa2.nNo; a++) {
+      cap_node_ids.insert(fa2.gN(a));
+    }
+  }
+}
+
+std::map<int, int> global_to_local;
+for (int a = 0; a < nNo; a++) {
+  int gid = lFa.gN(a);
+  if (cap_node_ids.count(gid)) continue; // exclude shared nodes
+  global_to_local[gid +1] = a;
+}
+
+  for (int iTP = 0; iTP < num_phases; iTP++) {
+    double t_val;
+    file >> t_val;
+    lMB.t(iTP) = t_val;
+
+    for (int k = 0; k < num_nodes_file; k++) {
+      int node_id;
+      double x, y, z;
+      file >> node_id >> x >> y >> z;
+
+      auto it = global_to_local.find(node_id);
+      if (it == global_to_local.end()) continue;
+
+      int local_idx = it->second;
+      int global_idx = lFa.gN(local_idx);
+
+      lMB.d(0, local_idx, iTP) = x - ref_coords(0, global_idx);
+      lMB.d(1, local_idx, iTP) = y - ref_coords(1, global_idx);
+      lMB.d(2, local_idx, iTP) = z - ref_coords(2, global_idx);
+    }
+  }
+
+  lMB.period = lMB.t(num_phases - 1);
+  file.close();
+}
 };
 
