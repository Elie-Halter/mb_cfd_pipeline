From ede0175863280d034ec1d707473c4cb113e0279c Mon Sep 17 00:00:00 2001
From: HALTER <halter.elie@gmail.com>
Date: Thu, 23 Apr 2026 11:04:45 +0200
Subject: [PATCH 07/13] mesh: apply stiffness-based diffusion and fail-fast on
 collapsed elements

Activates the stiffness-based mesh diffusion scheme in construct_mesh().
Per element, the local Lame coefficients passed to l_elas_3d/2d are
scaled by

    stiff_factor = (1 + eps) / (J^exponent + eps)

with eps = 1e-4 and exponent = eq.mesh_stiffness_exponent (default 0.0).
This rigidifies distorted elements (small J) and redirects mesh
deformation to healthier neighbors, stabilizing ALE simulations with
large wall displacements (Tezduyar et al.; see also Stein et al. 2003).

When the exponent is 0.0 (default), stiff_factor is exactly 1.0 and
no pow() call is performed, so existing behavior is preserved bit-for-bit.

Also adds a fail-fast guard: if the local Jacobian drops below
J_MIN_CRITICAL = 1e-6, construct_mesh throws with a clear message
pointing users toward enabling Mesh_stiffness_exponent, refining the
mesh locally, or reducing the prescribed displacement. This avoids the
pathological case where the mesh linear solver spends tens of thousands
of iterations on a near-singular matrix without making progress.
---
 Code/Source/solver/mesh.cpp | 31 +++++++++++++++++++++++++++++--
 1 file changed, 29 insertions(+), 2 deletions(-)

diff --git a/Code/Source/solver/mesh.cpp b/Code/Source/solver/mesh.cpp
index dcefae4..c54935b 100644
--- a/Code/Source/solver/mesh.cpp
+++ b/Code/Source/solver/mesh.cpp
@@ -27,6 +27,17 @@ void construct_mesh(ComMod& com_mod, CepMod& cep_mod, const mshType& lM, const S
   int    elem_worst = -1;
   // === fin CKP5 ===
 
+  // === Stiffness-based mesh diffusion (Tezduyar) ===
+  // When mesh_stiffness_exponent > 0, per-element Lame coefficients are scaled by
+  //   stiff_factor = (1 + eps) / (J^exponent + eps)
+  // so that distorted elements (small J) become locally rigid.
+  const double stiff_exp = com_mod.eq[com_mod.cEq].mesh_stiffness_exponent;
+  const double stiff_eps = 1.0e-4;
+  const bool   use_stiffness_scaling = (stiff_exp > 0.0);
+  // Fail-fast threshold: below this, the element is considered dead.
+  const double J_MIN_CRITICAL = 1.0e-6;
+  // === fin diffusion ===
+
   const auto& Do = solutions.old.get_displacement();
   const auto& Ag = solutions.intermediate.get_acceleration();
   const auto& Dg = solutions.intermediate.get_displacement();
@@ -115,6 +126,7 @@ void construct_mesh(ComMod& com_mod, CepMod& cep_mod, const mshType& lM, const S
     lR = 0.0;
     lK = 0.0;
     double Jac{0.0};
+    double stiff_factor = 1.0;
 
     for (int g = 0; g < lM.nG; g++) {
       if (g == 0 || !lM.lShpF) {
@@ -129,6 +141,21 @@ void construct_mesh(ComMod& com_mod, CepMod& cep_mod, const mshType& lM, const S
         if (utils::is_zero(Jac)) {
           throw std::runtime_error("[construct_mesh] Jacobian for element " + std::to_string(e) + " is < 0.");
         }
+
+        // === Fail-fast on critically small Jacobian (mesh element collapsed) ===
+        if (Jac < J_MIN_CRITICAL) {
+          throw std::runtime_error(
+            "[construct_mesh] Mesh element " + std::to_string(e) +
+            " has collapsed: J=" + std::to_string(Jac) +
+            " below critical threshold " + std::to_string(J_MIN_CRITICAL) +
+            ". Consider enabling Mesh_stiffness_exponent > 0, refining the mesh"
+            " locally, or reducing the prescribed wall displacement.");
+        }
+
+        // Update per-element stiffness factor (Tezduyar).
+        if (use_stiffness_scaling) {
+          stiff_factor = (1.0 + stiff_eps) / (std::pow(Jac, stiff_exp) + stiff_eps);
+        }
       }
 
       double w = lM.w(g);
@@ -136,10 +163,10 @@ void construct_mesh(ComMod& com_mod, CepMod& cep_mod, const mshType& lM, const S
       pS0l = 0.0;
 
       if (nsd == 3) {
-        l_elas::l_elas_3d(com_mod, eNoN, w, N, Nx, al, dl, bfl, pS0l, pSl, lR, lK);
+        l_elas::l_elas_3d(com_mod, eNoN, w, N, Nx, al, dl, bfl, pS0l, pSl, lR, lK, stiff_factor);
 
       } else if (nsd == 2) {
-        l_elas::l_elas_2d(com_mod, eNoN, w, N, Nx, al, dl, bfl, pS0l, pSl, lR, lK);
+        l_elas::l_elas_2d(com_mod, eNoN, w, N, Nx, al, dl, bfl, pS0l, pSl, lR, lK, stiff_factor);
       }
     }
 
