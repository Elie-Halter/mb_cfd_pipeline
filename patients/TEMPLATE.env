# ============================================================================
#  Patient config for run_patient.sh — COPY to patients/<patient>.env and fill in.
#  The only non-scripted prerequisite = the segmented phase STLs (from imaging).
# ============================================================================

# --- identity & outputs ---
PATIENT=PXXXX                                   # patient identifier (anonymized)
WORK=/path/to/$PATIENT/work                     # working dir (mesh, displacement, post-processing results)
RUNROOT=/path/to/$PATIENT                        # root dir for the FB/MB runs

# --- segmentation INPUTS (4D-flow) ---
REF_STL=/path/to/$PATIENT/ref_phase_capped.stl  # reference surface (phase t=0), capped
ORIG_SURF=/path/to/$PATIENT/ref_surfaces        # reference surfaces dir (to tag the caps), or the same mesh
# cyclic phases: "t_frac:path.stl" (t in (0,1)), space-separated.
PHASES="0.40:/path/to/$PATIENT/phaseA.stl 0.60:/path/to/$PATIENT/phaseB.stl 0.80:/path/to/$PATIENT/phaseC.stl 0.95:/path/to/$PATIENT/phaseD.stl"

# --- patient physiology / MRI (for RCR calibration, GATE G2) ---
# args passed as-is to calibrate_rcr.py (--flow wave.txt OR --qmean; --map MAP;
# and the per-outlet MRI split, per the calibrate_rcr interface).
RCR_ARGS="--flow /path/to/$PATIENT/inlet_flow.txt --map <MAP_mmHg>"
OUTLETS="desc,btca,lcca,lsa"                     # logical outlet names (bcca<->btca alias handled)

# --- numerics ---
T_CYCLE=0.974      # cardiac cycle duration (s)
SCALE=0.1          # mm -> cm
NSTEPS=1948        # total steps (974/cycle x 2 cycles)
CYC0=974           # last-cycle window for TAWSS/OSI
CYC1=1948
NPROCS=4
SURF_HMAX=0.5      # reference-mesh surface edge length (build_iso_mesh)

# --- tool paths (defaults usually fine) ---
# FABLE_CODE=/path/to/morph
# SVMP_BIN=svmultiphysics
